    {
      "name": "Create board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let response = pm.response.json();\r",
              "pm.collectionVariables.set(\"boardId\", response.id);\r",
              "\r",
              "pm.test(\"Board is created\", function () {\r",
              "    pm.expect(response.name).to.eql(\"Learning Postman \" + pm.collectionVariables.get(\"boardNumber\"));\r",
              "    pm.expect(response.closed).to.eql(false);\r",
              "});\r",
              "\r",
              "pm.test(\"Board is private\", function () {\r",
              "    pm.expect(response.prefs.permissionLevel).to.eql(\"private\");\r",
              "});\r",
              "\r",
              "pm.test(\"Calendar is disabled\", function () {\r",
              "    pm.expect(response.prefs.switcherViews[2].enabled).to.eql(false);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//Initializez o variabila boardNumber care sa se adauge la numele board-ului:\r",
              "\r",
              "let boardNumber = pm.collectionVariables.get(\"boardNumber\"); //2. Stochez in variabila boardNumber valoarea din var de colectie boardNumber si o incrementez cu 1. Daca nu e un numar, o initializam cu 0.\r",
              "//console.log(boardNumber);\r",
              "if (isNaN(boardNumber)){\r",
              "    boardNumber = 0;\r",
              "}\r",
              "boardNumber++;\r",
              "pm.collectionVariables.set(\"boardNumber\", boardNumber); //1. O initializez si o setez.\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
